{
  "name": "ucal",
  "displayName": "ucal",
  "repository": {
    "type": "git",
    "url": "https://github.com/konyahin/ucal.git",
    "directory": "vscode-plugin"
  },
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ucal.calculate",
        "title": "ucal: calculate expression with ranges"
      }
    ],
    "configuration": {
      "title": "ucal",
      "properties": {
        "ucal.binaryPath": {
          "type": "string",
          "default": "ucal",
          "description": "Path to the ucal binary used in -serve mode."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "markdown-it": "^14.1.0",
    "vscode-jsonrpc": "^8.2.1"
  }
}
